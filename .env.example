# 应用基础信息
# 应用名称，用于文档展示、日志标识等场景
APP_NAME=Baozhi RAG Service
# 运行环境标识，例如 local、test、prod
APP_ENV=local
# 是否开启调试模式，开启后通常会输出更详细的错误信息
APP_DEBUG=true
# 当前服务版本号
APP_VERSION=0.1.0
# 日志级别，可选如 DEBUG、INFO、WARNING、ERROR
APP_LOG_LEVEL=INFO

# 跨域配置
# 允许跨域访问的前端来源，多个来源使用英文逗号分隔；留空表示不启用后端 CORS
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000
# 可选的来源正则表达式；适合需要放行一组动态子域时使用，留空表示不启用
CORS_ALLOW_ORIGIN_REGEX=
# 是否允许浏览器跨域请求携带 Cookie 等凭证；如前后端采用 Cookie 会话可改为 true
CORS_ALLOW_CREDENTIALS=false
# 允许跨域请求使用的 HTTP 方法，多个方法使用英文逗号分隔
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# 允许跨域请求携带的请求头，多个请求头使用英文逗号分隔
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Request-ID
# 允许前端读取的响应头，默认暴露请求追踪头
CORS_EXPOSE_HEADERS=X-Request-ID

# 本地文件存储
# 上传文件保存的根目录，支持相对路径和绝对路径
UPLOAD_ROOT_DIR=data/uploads

# Word 切块配置
# 单个文档切块的目标字符长度
DOC_CHUNK_SIZE=800
# 相邻切块之间保留的重叠字符数，用于降低语义断裂
DOC_CHUNK_OVERLAP=150
# 旧版 Word 文档转换时使用的临时目录
DOC_CONVERT_TEMP_DIR=data/tmp/converted

# 服务端镜像构建源配置
# 腾讯云服务器建议保留默认值；若构建阶段下载缓慢，可临时改为官方源或其他镜像源
APP_BUILD_APT_MIRROR=https://mirrors.cloud.tencent.com
APP_BUILD_PYPI_MIRROR=https://mirrors.cloud.tencent.com/pypi/simple

# 可选的外部领域词典文件路径，按行存储词项；留空表示只使用默认领域词典文件
DOMAIN_DICTIONARY_PATH=

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=baozhi_rag
MYSQL_USERNAME=baozhi
MYSQL_PASSWORD=baozhi123456

# JWT 鉴权配置
# JWT 用于登录态校验，默认有效期 7 天；生产环境务必替换为高强度随机密钥
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7


# 阿里云 OSS 对象存储配置
# 上传后的原始文件会持久化到阿里云 OSS；UPLOAD_ROOT_DIR 仅作为本地临时工作目录
OSS_REGION=cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_OBJECT_PREFIX=knowledge-files

# 注册邮箱验证码配置
# 该密钥用于生成验证码摘要，生产环境请替换为独立的高强度随机密钥
REGISTRATION_CODE_SECRET=replace-with-a-long-random-registration-code-secret
# 验证码位数，当前实现默认使用纯数字验证码
REGISTRATION_CODE_LENGTH=6
# 验证码有效期，单位为分钟
REGISTRATION_CODE_EXPIRE_MINUTES=10
# 同一邮箱两次发码之间的冷却时间，单位为秒
REGISTRATION_CODE_RESEND_INTERVAL_SECONDS=60
# 单个验证码最多允许输错的次数
REGISTRATION_CODE_MAX_ATTEMPTS=5

# SMTP 邮件发送配置
# 注册验证码邮件将使用以下发件邮箱发送
# SMTP 服务地址，例如 QQ 邮箱、企业邮箱、SendGrid、阿里云邮件推送提供的主机名
SMTP_HOST=smtp.example.com
# SMTP 服务端口；常见为 587（STARTTLS）或 465（SMTPS）
SMTP_PORT=587
# SMTP 登录账号；很多服务要求填完整邮箱地址
SMTP_USERNAME=notice@example.com
# SMTP 登录密码；有些邮箱服务这里要填“授权码”而不是邮箱登录密码
SMTP_PASSWORD=replace-with-smtp-password
# 明文 SMTP 通常配合 STARTTLS；若使用 SMTPS，请把 SMTP_USE_SSL 改为 true 并关闭 SMTP_USE_TLS
# 是否在普通 SMTP 连接建立后升级到 TLS 加密；587 端口通常为 true
SMTP_USE_TLS=true
# 是否直接使用 SSL/TLS 建立加密连接；465 端口通常为 true
SMTP_USE_SSL=false
# 收件人看到的实际发件邮箱地址，决定“这封验证码邮件是谁发的”
SMTP_FROM_EMAIL=notice@example.com
# 收件人看到的发件人名称，一般显示为产品名或公司名
SMTP_FROM_NAME=Baozhi RAG Service
# 连接 SMTP 和发送邮件时的超时时间，单位为秒
SMTP_TIMEOUT_SECONDS=10

# Elasticsearch 检索配置（必选依赖）
# Elasticsearch 服务在当前系统中为必选，默认建议使用仓库内置的 IK 版本 docker compose
# Elasticsearch 服务地址
ES_URL=http://127.0.0.1:9200
# chunk 文档写入和检索使用的索引名称
ES_INDEX_NAME=document_chunks
# Elasticsearch 用户名；当前本机开发环境关闭认证时可留空
ES_USERNAME=
# Elasticsearch 密码；当前本机开发环境关闭认证时可留空
ES_PASSWORD=
# Elasticsearch API Key；与用户名密码二选一，未启用时留空
ES_API_KEY=
# 是否校验 Elasticsearch HTTPS 证书；本机无证书调试环境通常设为 false
ES_VERIFY_CERTS=false

# Milvus 向量存储配置（上传与语义检索必选）
# Milvus 服务地址；本机 docker compose 默认使用 19530 端口
MILVUS_URI=http://127.0.0.1:19530
# Milvus 认证令牌；本机未开启认证时可留空
MILVUS_TOKEN=
# Milvus 数据库名称；默认使用 default
MILVUS_DB_NAME=default
# chunk 向量写入的集合名称
MILVUS_COLLECTION_NAME=document_chunk_vectors

# 阿里云百炼模型配置（上传与检索链路必选）
# DashScope API Key；向量化链路必填
DASHSCOPE_API_KEY=
# 百炼 OpenAI 兼容接口地址；中国站通常使用以下默认值
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 百炼模型调用超时时间（秒）
BAILIAN_TIMEOUT_SECONDS=30
# 聊天模型名称；启用 /chat/completions 聊天接口时必填
BAILIAN_CHAT_MODEL=
# 聊天接口系统提示词；默认允许无证据时回答通用问题，但高风险问题仍需明确提示证据不足
CHAT_SYSTEM_PROMPT=你是金融保险问答助手。如果当前轮提供了知识库证据，优先只基于证据回答，并在相关句子后追加 [1][2] 这类证据编号。如果当前轮没有提供知识库证据，你仍可以回答问候、身份说明、能力介绍和一般性概念解释，但不得把未验证内容表述为具体条款、保障责任、免责结论、理赔结论或确定性承诺。遇到具体产品、保单、承保、理赔、免责、金额计算等高风险问题且缺少证据时，必须明确说明“当前没有检索到可支撑结论的知识库材料”，只能提供一般性说明，并建议补充材料或转人工核实。涉及理赔、承保、免责、保单解释时，要明确说明以正式合同条款、系统记录和人工审核结果为准。

# Chunk 向量化配置
# 默认使用阿里云百炼的通用文本向量模型
CHUNK_EMBEDDING_MODEL=text-embedding-v4
# 向量维度；建议先从 1024 开始
CHUNK_EMBEDDING_DIMENSIONS=1024
# 单次批量向量化请求的最大文本条数；百炼 embedding 接口单次最多支持 10 条
CHUNK_EMBEDDING_BATCH_SIZE=10

# 检索接口默认返回条数
# /search/chunks 等检索接口默认返回的命中数量
SEARCH_DEFAULT_SIZE=10


