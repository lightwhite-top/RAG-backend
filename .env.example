# 应用基础信息
# 应用名称，用于文档展示、日志标识等场景
APP_NAME=Baozhi RAG Service
# 运行环境标识，例如 local、test、prod
APP_ENV=local
# 是否开启调试模式，开启后通常会输出更详细的错误信息
APP_DEBUG=true
# 当前服务版本号
APP_VERSION=0.1.0
# 日志级别，可选如 DEBUG、INFO、WARNING、ERROR
APP_LOG_LEVEL=INFO

# 本地文件存储
# 上传文件保存的根目录，支持相对路径和绝对路径
UPLOAD_ROOT_DIR=data/uploads

# Word 切块配置
# 单个文档切块的目标字符长度
DOC_CHUNK_SIZE=800
# 相邻切块之间保留的重叠字符数，用于降低语义断裂
DOC_CHUNK_OVERLAP=150
# 旧版 Word 文档转换时使用的临时目录
DOC_CONVERT_TEMP_DIR=data/tmp/converted

# 可选的外部领域词典文件路径，按行存储词项；留空表示只使用内置金融保险词典
DOMAIN_DICTIONARY_PATH=

# Elasticsearch 检索配置（必选依赖）
# Elasticsearch 服务在当前系统中为必选，启动前请确保可用
# Elasticsearch 服务地址
ES_URL=http://127.0.0.1:9200
# chunk 文档写入和检索使用的索引名称
ES_INDEX_NAME=document_chunks
# Elasticsearch 用户名；当前本机开发环境关闭认证时可留空
ES_USERNAME=
# Elasticsearch 密码；当前本机开发环境关闭认证时可留空
ES_PASSWORD=
# Elasticsearch API Key；与用户名密码二选一，未启用时留空
ES_API_KEY=
# 是否校验 Elasticsearch HTTPS 证书；本机无证书调试环境通常设为 false
ES_VERIFY_CERTS=false

# Milvus 向量存储配置（上传与语义检索必选）
# Milvus 服务地址；本机 docker compose 默认使用 19530 端口
MILVUS_URI=http://127.0.0.1:19530
# Milvus 认证令牌；本机未开启认证时可留空
MILVUS_TOKEN=
# Milvus 数据库名称；默认使用 default
MILVUS_DB_NAME=default
# chunk 向量写入的集合名称
MILVUS_COLLECTION_NAME=document_chunk_vectors

# 阿里云百炼模型配置（上传与检索链路必选）
# DashScope API Key；向量化链路必填
DASHSCOPE_API_KEY=
# 百炼 OpenAI 兼容接口地址；中国站通常使用以下默认值
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 百炼模型调用超时时间（秒）
BAILIAN_TIMEOUT_SECONDS=30
# 预留的聊天模型名称；后续接入聊天链路时可直接复用
BAILIAN_CHAT_MODEL=

# Chunk 向量化配置
# 默认使用阿里云百炼的通用文本向量模型
CHUNK_EMBEDDING_MODEL=text-embedding-v4
# 向量维度；建议先从 1024 开始
CHUNK_EMBEDDING_DIMENSIONS=1024
# 单次批量向量化请求的最大文本条数；百炼 embedding 接口单次最多支持 10 条
CHUNK_EMBEDDING_BATCH_SIZE=10

# 检索接口默认返回条数
# /search/chunks 等检索接口默认返回的命中数量
SEARCH_DEFAULT_SIZE=10
